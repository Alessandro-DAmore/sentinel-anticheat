SENTINEL_HOST=0.0.0.0
SENTINEL_PORT=8787
SENTINEL_PUBLIC_BASE_URL=https://sentinel-anticheat.example.com

SENTINEL_SHARED_SECRET=replace_with_64_plus_random_chars
SENTINEL_LICENSE_KEYS=replace_license_key_1,replace_license_key_2
SENTINEL_SERVER_KEYS=replace_server_key_1
SENTINEL_DASHBOARD_TOKEN=replace_admin_dashboard_token
SENTINEL_ADMIN_USER=admin
SENTINEL_ADMIN_PASSWORD=replace_long_admin_password

DISCORD_CLIENT_ID=replace_discord_application_client_id
DISCORD_CLIENT_SECRET=replace_discord_application_client_secret
DISCORD_REDIRECT_URI=https://sentinel-anticheat.example.com/auth/discord/callback

# Persistent download storage. Recommended provider: Cloudflare R2.
SENTINEL_STORAGE_PROVIDER=r2
SENTINEL_STORAGE_PREFIX=downloads
SENTINEL_R2_ACCOUNT_ID=replace_cloudflare_account_id
SENTINEL_R2_BUCKET=sentinel-anticheat-downloads
SENTINEL_R2_ACCESS_KEY_ID=replace_r2_access_key_id
SENTINEL_R2_SECRET_ACCESS_KEY=replace_r2_secret_access_key
SENTINEL_R2_PUBLIC_BASE_URL=https://downloads.example.com
